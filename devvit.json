{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "mod-pit",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create ModPit dashboard",
        "description": "Create a new ModPit clustering dashboard post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "ModPit",
        "description": "Open ModPit dashboard",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/open-dashboard"
      },
      {
        "label": "ModPit",
        "description": "Open ModPit dashboard",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/open-dashboard"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onPostReport": "/internal/triggers/on-post-report"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "mod_pit_dev"
  }
}
